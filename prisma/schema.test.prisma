// This schema is used for E2E testing with SQLite
generator client {
  provider        = "prisma-client-js"
  output          = "./generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ============================================
// Lookup / Enum Tables
// ============================================

model UserRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  createdAt   DateTime @default(now())
  users       User[]
}

// ============================================
// Auth & User Management
// ============================================

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  emailVerified          DateTime?
  fullName               String
  fiscalDocument         String?   @unique
  password               String
  avatar                 String?
  locale                 String    @default("pt-BR")
  role                   UserRole  @relation(fields: [roleId], references: [id])
  roleId                 String
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  organizations          Member[]
  billingSubscriptions   BillingSubscription[]
  billingInvoices        BillingInvoice[]
  auditLogs              AuditLog[]
}

model Member {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  role           String   @default("member")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, organizationId])
}

// ============================================
// Organizations & Projects
// ============================================

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  description          String?
  logoUrl              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  members              Member[]
  projects             Project[]
  billingSubscriptions BillingSubscription[]
  metaConnections      MetaConnection[]
  whatsappConnections  WhatsAppConnection[]
  auditLogs            AuditLog[]
}

model Project {
  id              String   @id @default(cuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  name            String
  slug            String
  description     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  campaigns       Campaign[]
  conversions     Conversion[]
  leads           Lead[]
  items           Item[]
  tickets         Ticket[]

  @@unique([organizationId, slug])
}

// ============================================
// Billing & Subscription
// ============================================

model BillingPlan {
  id                                 String   @id @default(cuid())
  code                               String   @unique
  name                               String
  cycle                              String   // MONTHLY, YEARLY
  accessDays                         Int
  includedProjects                   Int
  includedWhatsAppPerProject         Int      @default(1)
  includedConversionsPerProject      Int      @default(0) // 0 = unlimited
  includedMetaAdAccountsPerProject   Int      @default(1)
  sortOrder                          Int      @default(0)
  displayOrder                       Int      @default(999)
  isActive                           Boolean  @default(true)
  isHighlighted                      Boolean  @default(false)
  contactSalesOnly                   Boolean  @default(false)
  supportLevel                       String?  // BASIC, PRIORITY, DEDICATED
  metadata                           Json      // JSON
  offers                             BillingOffer[]
  subscriptions                      BillingSubscription[]
  planHistory                        BillingPlanHistory[]
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @updatedAt
}

model BillingOffer {
  id                  String   @id @default(cuid())
  plan                BillingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId              String
  code                String
  paymentMethod       String   // CREDIT_CARD, PIX, BOLETO
  currency            String   @default("BRL")
  amount              Decimal
  installmentRate     Decimal @default(0) // 0.029 = 2.9% per installment
  maxInstallments     Int      @default(12)
  isActive            Boolean  @default(true)
  validUntil          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([planId, paymentMethod])
}

model BillingSubscription {
  id                  String   @id @default(cuid())
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId      String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  currentPlan         BillingPlan? @relation(fields: [currentPlanId], references: [id])
  currentPlanId       String?
  status              String   @default("ACTIVE") // ACTIVE, TRIAL, SUSPENDED, CANCELLED
  trialEndsAt         DateTime?
  cycleStartDate      DateTime @default(now())
  cycleEndDate        DateTime
  nextBillingDate     DateTime?
  asaasSubscriptionId String?  @unique
  metadata            Json      // JSON
  planHistory         BillingPlanHistory[]
  invoices            BillingInvoice[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model BillingPlanHistory {
  id                   String   @id @default(cuid())
  subscription         BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId       String
  plan                 BillingPlan @relation(fields: [planId], references: [id])
  planId               String
  reason               String   // trial_to_paid, auto_upgrade, manual, downgrade
  projectCountAtChange Int
  startedAt            DateTime @default(now())
  endedAt              DateTime?
  createdAt            DateTime @default(now())
}

model BillingInvoice {
  id                  String   @id @default(cuid())
  subscription        BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId      String
  user                User     @relation(fields: [userId], references: [id])
  userId              String
  planId              String
  amount              Decimal
  creditApplied       Decimal @default(0)
  chargeAmount        Decimal @default(0)
  daysProrated        Int?
  proratingReason     String? // auto_upgrade, downgrade, etc
  status              String   @default("PENDING") // PENDING, PAID, FAILED, CANCELLED
  asaasInvoiceId      String?  @unique
  paidAt              DateTime?
  dueDate             DateTime
  metadata            Json      // JSON
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ============================================
// Meta Ads & Integrations
// ============================================

model MetaConnection {
  id              String   @id @default(cuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  wabaId          String   @unique
  phoneNumberId   String?
  accessToken     String
  metadata        Json      // JSON
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  campaigns       Campaign[]
}

model WhatsAppConnection {
  id              String   @id @default(cuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  phoneNumber     String   @unique
  phoneNumberId   String   @unique
  displayName     String
  accessToken     String
  metadata        Json      // JSON
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  campaigns       Campaign[]
  conversations   Conversation[]
}

// ============================================
// Campaigns & Messaging
// ============================================

model Campaign {
  id                   String   @id @default(cuid())
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId            String
  metaConnection       MetaConnection? @relation(fields: [metaConnectionId], references: [id], onDelete: SetNull)
  metaConnectionId     String?
  whatsappConnection   WhatsAppConnection? @relation(fields: [whatsappConnectionId], references: [id], onDelete: SetNull)
  whatsappConnectionId String?
  name                 String
  description          String?
  status               String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, SCHEDULED, RUNNING, COMPLETED, FAILED
  templateId           String?
  scheduledAt          DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  executionInstances   CampaignExecution[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model CampaignExecution {
  id           String   @id @default(cuid())
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId   String
  status       String   @default("RUNNING")
  totalRecipients   Int
  successCount Int      @default(0)
  failureCount Int      @default(0)
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  recipients   CampaignRecipient[]
  createdAt    DateTime @default(now())
}

model CampaignRecipient {
  id           String   @id @default(cuid())
  execution    CampaignExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  executionId  String
  phoneNumber  String
  status       String   @default("PENDING")
  message      String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  errorMessage String?
  metadata     Json      // JSON
}

// ============================================
// Conversations & Tickets
// ============================================

model Conversation {
  id                   String   @id @default(cuid())
  whatsappConnection   WhatsAppConnection @relation(fields: [whatsappConnectionId], references: [id], onDelete: Cascade)
  whatsappConnectionId String
  phoneNumber          String
  status               String   @default("OPEN")
  lastMessageAt        DateTime @default(now())
  metadata             Json      // JSON
  messages             Message[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([whatsappConnectionId, phoneNumber])
}

model Message {
  id              String   @id @default(cuid())
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId  String
  messageId       String   @unique
  direction       String   // INBOUND, OUTBOUND
  content         String
  mediaUrl        String?
  mediaType       String?
  status          String   @default("DELIVERED")
  metadata        Json      // JSON
  createdAt       DateTime @default(now())
}

model Ticket {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  title       String
  description String?
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  assignee    String?
  metadata    Json      // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// Sales & CRM
// ============================================

model Lead {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  name        String
  email       String?
  phone       String?
  source      String?
  status      String   @default("NEW")
  metadata    Json      // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Conversion {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  conversionId String   @unique
  value       Decimal
  currency    String   @default("BRL")
  metadata    Json      // JSON
  createdAt   DateTime @default(now())
}

// ============================================
// Inventory
// ============================================

model Item {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  name        String
  sku         String
  price       Decimal
  quantity    Int
  metadata    Json      // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// Audit & Logging
// ============================================

model AuditLog {
  id              String   @id @default(cuid())
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationId  String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId          String?
  action          String
  resourceType    String
  resourceId      String?
  before          Json?
  after           Json?
  ipAddress       String?
  userAgent       String?
  metadata        Json      // JSON
  createdAt       DateTime @default(now())
}
