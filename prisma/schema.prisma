  project      Project?       @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@unique([projectId, adAccountId])
  @@unique([organizationId, adAccountId])
  @@index([projectId])
  @@index([organizationId, projectId])
  @@map("meta_ad_accounts")
}

model MetaPixel {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String @db.Uuid
  projectId      String? @db.Uuid

  name      String? // Nome opcional
  pixelId   String // Dataset/Pixel ID para envio CAPI
  capiToken String // Conversions API Access Token
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@unique([projectId, pixelId])
  @@unique([organizationId, pixelId])
  @@index([projectId])
  @@index([organizationId, projectId])
  @@map("meta_pixels")
}

model MetaConversionEvent {
