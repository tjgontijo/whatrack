  syncedAt        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([organizationId, projectId, date, entityKey])
  @@index([organizationId, projectId, date])
  @@index([date])
  @@map("analytics_meta_ad_insights_daily")
}

model CurrencyExchangeRateDaily {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  date           DateTime @db.Date
  baseCurrency   String   // BRL
  quoteCurrency  String   // USD
  rate           Decimal  @db.Decimal(10, 6)
  source         String   @default("FIXED") // FIXED | API

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date, baseCurrency, quoteCurrency])
  @@index([organizationId, date])
  @@map("analytics_currency_exchange_rates_daily")
}

model DashboardMetricRefreshRun {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  projectId      String?  @db.Uuid

  startDate      DateTime @db.Date
  endDate        DateTime @db.Date

  status         String   @default("PENDING") // PENDING | RUNNING | SUCCESS | FAILED
  startedAt      DateTime @default(now())
  completedAt    DateTime?

  rowsInserted   Int      @default(0)
  rowsUpdated    Int      @default(0)
  errorMessage   String?
  jobId          String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, projectId])
  @@index([status])
  @@index([completedAt(sort: Desc)])
  @@map("analytics_dashboard_metric_refresh_runs")
}

model DashboardDailyMetric {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  projectId      String?  @db.Uuid

  date           DateTime @db.Date

  // Revenue
  revenueCompleted    Decimal @db.Decimal(12, 2) @default(0)
  revenuePending      Decimal @db.Decimal(12, 2) @default(0)
  revenuePipeline     Decimal @db.Decimal(12, 2) @default(0)

  // Meta Paid
  metaPaidSpend       Decimal @db.Decimal(12, 2) @default(0)
  metaPaidRevenue     Decimal @db.Decimal(12, 2) @default(0)
  metaPaidClicks      Int     @default(0)
  metaPaidImpressions Int     @default(0)

  // Other Paid
  otherPaidSpend      Decimal @db.Decimal(12, 2) @default(0)
  otherPaidRevenue    Decimal @db.Decimal(12, 2) @default(0)

  // Leads
  leadsTotal          Int     @default(0)
  leadsMetaPaid       Int     @default(0)

  // Sales
  salesTotal          Int     @default(0)
  salesMetaAttribued  Int     @default(0)

  lastProjectedAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([organizationId, projectId, date])
  @@index([organizationId, projectId, date])
  @@map("analytics_dashboard_daily_metrics")
}

model DashboardOriginDailyMetric {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  projectId      String?  @db.Uuid

  date           DateTime @db.Date

  // Origin Key - nao-nullable composite identifier
  originKey      String   // ex: "meta_paid:utm_source:utm_medium:utm_campaign"

  // UTM optional info (denormalized)
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?

  // Metrics
  leadsCount     Int     @default(0)
  salesCount     Int     @default(0)
  revenue        Decimal @db.Decimal(12, 2) @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([organizationId, projectId, date, originKey])
  @@index([organizationId, projectId, date])
  @@map("analytics_dashboard_origin_daily_metrics")
}

model DashboardMetaEntityDailyMetric {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  projectId      String?  @db.Uuid

  date           DateTime @db.Date

  // Meta Entity IDs
  metaCampaignId String
  metaAdSetId    String?
  metaAdId       String?

  // Entity Key
  entityKey      String

  // Metrics
  spend          Decimal @db.Decimal(12, 2) @default(0)
  clicks         Int     @default(0)
  impressions    Int     @default(0)
  leadsAttribued Int     @default(0)
  revenue        Decimal @db.Decimal(12, 2) @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([organizationId, projectId, date, entityKey])
  @@index([organizationId, projectId, date])
  @@map("analytics_dashboard_meta_entity_daily_metrics")
}

// ============================================
// Audit Domain
// ============================================

model OrgAuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?  @db.Uuid // nullable: suporte a eventos globais (ex: registro)
  userId         String?  @db.Uuid // nullable: suporte a ações de sistema
  action         String
  resourceType   String
  resourceId     String?
  before         Json?
  after          Json?
  ip             String?
  userAgent      String?
  requestId      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@index([requestId])
  @@map("org_audit_logs")
}

// ============================================
// Billing Domain
// ============================================

model BillingSubscriptionStatus {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String                @unique
  description   String
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  subscriptions BillingSubscription[]

  @@map("billing_subscription_statuses")
}

model BillingFailureReason {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String                @unique
  description   String
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  subscriptions BillingSubscription[]

  @@map("billing_failure_reasons")
}

model BillingInvoiceStatus {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String           @unique
  description String
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  invoices    BillingInvoice[]

  @@map("billing_invoice_statuses")
}

model BillingPaymentMethod {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String                @unique
  description   String
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  subscriptions BillingSubscription[]
  offers        BillingOffer[]
  invoices      BillingInvoice[]

  @@map("billing_payment_methods")
}

model BillingCycle {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String        @unique
  description String
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  plans       BillingPlan[]

  @@map("billing_cycles")
}

model AuditActor {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String            @unique
  description String
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  auditLogs   BillingAuditLog[]

  @@map("billing_audit_actors")
}

model BillingSubscription {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId            String    @unique @db.Uuid
  offerId                   String?   @db.Uuid
  currentPlanId             String?   @db.Uuid
  asaasId                   String?   @unique
  asaasCustomerId           String?
  pixAutomaticAuthId        String?   @unique
  status                    String    @default("INACTIVE")
  paymentMethod             String?
  isActive                  Boolean   @default(false)
  purchaseDate              DateTime  @default(now())
  expiresAt                 DateTime?
  canceledAt                DateTime?
  trialEndsAt               DateTime?
  failureReason             String?
  failureCount              Int       @default(0)
  lastFailureAt             DateTime?
  lastFailureMessage        String?
  nextRetryAt               DateTime?
  lastRetryAt               DateTime?
  failureNotificationSentAt DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  offer            BillingOffer?             @relation(fields: [offerId], references: [id])
  currentPlan      BillingPlan?              @relation("currentPlan", fields: [currentPlanId], references: [id], onDelete: SetNull)
  invoices         BillingInvoice[]
  planHistory      BillingPlanHistory[]
  statusRef        BillingSubscriptionStatus @relation(fields: [status], references: [name])
  paymentMethodRef BillingPaymentMethod?     @relation(fields: [paymentMethod], references: [name])
  failureReasonRef BillingFailureReason?     @relation(fields: [failureReason], references: [name])

  @@index([organizationId])
  @@index([offerId])
  @@index([currentPlanId])
  @@index([asaasId])
  @@index([status])
  @@index([isActive])
  @@index([expiresAt])
  @@index([trialEndsAt])
  @@map("billing_subscriptions")
}

model BillingPlan {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String   @unique
  name       String
  cycle      String
  accessDays Int
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Entitlements
  includedProjects                 Int    @default(0)
  includedWhatsAppPerProject       Int    @default(0)
  includedMetaAdAccountsPerProject Int    @default(0)
  includedConversionsPerProject    Int    @default(0)
  supportLevel                     String @default("standard")

  // Display
  displayOrder     Int     @default(0)
  isHighlighted    Boolean @default(false)
  contactSalesOnly Boolean @default(false)

  // Metadata
  metadata Json?

  offers               BillingOffer[]
  currentSubscriptions BillingSubscription[] @relation("currentPlan")
  planHistory          BillingPlanHistory[]
  cycleRef             BillingCycle          @relation(fields: [cycle], references: [name])

  @@index([isActive])
  @@map("billing_plans")
}

model BillingOffer {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String    @unique
  planId          String    @db.Uuid
  paymentMethod   String
  amount          Decimal   @db.Decimal(10, 2)
  currency        String    @default("BRL")
  maxInstallments Int       @default(1)
  installmentRate Decimal?  @db.Decimal(6, 4)
  isActive        Boolean   @default(true)
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  plan             BillingPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscriptions    BillingSubscription[]
  invoices         BillingInvoice[]
  paymentMethodRef BillingPaymentMethod  @relation(fields: [paymentMethod], references: [name])

  @@index([planId])
  @@index([planId, paymentMethod, isActive])
  @@map("billing_offers")
}

model BillingInvoice {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String    @db.Uuid
  subscriptionId    String?   @db.Uuid
  offerId           String?   @db.Uuid
  asaasId           String    @unique
  status            String    @default("PENDING")
  paymentMethod     String
  value             Decimal   @db.Decimal(10, 2)
  netValue          Decimal?  @db.Decimal(10, 2)
  description       String?
  billingType       String
  dueDate           DateTime
  paidAt            DateTime?
  refundedAt        DateTime?
  invoiceUrl        String?
  bankSlipUrl       String?
  pixQrCode         String?
  pixQrCodePayload  String?
  pixQrCodeImage    String?
  pixExpirationDate DateTime?
  pixEmailSentAt    DateTime?
  pixWhatsappSentAt DateTime?
  pixResendCount    Int       @default(0)
  pixLastResendAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription     BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  offer            BillingOffer?        @relation(fields: [offerId], references: [id], onDelete: SetNull)
  statusRef        BillingInvoiceStatus @relation(fields: [status], references: [name])
  paymentMethodRef BillingPaymentMethod @relation(fields: [paymentMethod], references: [name])

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([offerId])
  @@index([asaasId])
  @@index([status])
  @@map("billing_invoices")
}

model BillingPlanHistory {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId       String   @db.Uuid
  planId               String   @db.Uuid
  startedAt            DateTime @default(now())
  endedAt              DateTime?
  reason               String
  projectCountAtChange Int
  createdAt            DateTime @default(now())

  subscription BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  plan         BillingPlan         @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([subscriptionId])
  @@index([planId])
  @@index([subscriptionId, startedAt(sort: Desc)])
  @@map("billing_plan_history")
}

model BillingAuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?  @db.Uuid
  userId         String?  @db.Uuid
  actor          String   @default("SYSTEM")
  action         String
  entity         String
  entityId       String
  asaasEventId   String?  @unique
  asaasPaymentId String?
  previousState  Json?
  newState       Json?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorRef     AuditActor    @relation(fields: [actor], references: [name])

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([asaasEventId])
  @@map("billing_audit_logs")
}

// ============================================
// WhatsApp Template Analytics
// ============================================

model WhatsAppTemplateLog {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wamid          String    @unique
  templateName   String
  organizationId String    @db.Uuid
  sentAt         DateTime  @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?
  repliedAt      DateTime?
  clickedAt      DateTime?

  @@index([organizationId, templateName])
  @@index([organizationId, sentAt])
  @@map("whatsapp_template_logs")
}
