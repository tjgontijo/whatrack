generator client {
  provider        = "prisma-client-js"
  output          = "./generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgcrypto]
}

// ============================================
// Lookup / Enum Tables
// ============================================

model UserRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("auth_user_roles")
}

model LeadSource {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String @unique
  description String
  leads       Lead[]

  @@map("crm_lead_sources")
}

model DealStatus {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String
  deals       Deal[]

  @@map("crm_deal_statuses")
}

model MessageDirection {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique
  description String
  messages    Message[]

  @@map("crm_message_directions")
}

model OnboardingStatus {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("org_onboarding_statuses")
}

model SaleStatus {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sales       Sale[]

  @@map("crm_sale_statuses")
}

model WhatsAppOnboardingStatus {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String               @unique
  description String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  onboardings WhatsAppOnboarding[]

  @@map("whatsapp_onboarding_statuses")
}

model WhatsAppConnectionStatus {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String               @unique
  description String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  connections WhatsAppConnection[]

  @@map("whatsapp_connection_statuses")
}

model WhatsAppHealthStatus {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String               @unique
  description  String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  connections  WhatsAppConnection[] @relation("ConnectionHealthStatus")
  healthChecks WhatsAppHealth[]     @relation("HealthStatus")

  @@map("whatsapp_health_statuses")
}

model WhatsAppAuditAction {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String             @unique
  description String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  auditLogs   WhatsAppAuditLog[]

  @@map("whatsapp_audit_actions")
}

model User {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  email              String             @unique
  phone              String?            @unique
  emailVerified      Boolean?           @default(true)
  image              String?
  role               String             @default("user")
  banned             Boolean            @default(false)
  banReason          String?
  banExpires         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  accounts           Account[]
  invitations        Invitation[]
  members            Member[]
  sessions           Session[]
  assignedDeals      Deal[]             @relation("DealAssignee")
  orgAuditLogs       OrgAuditLog[]
  billingAuditLogs   BillingAuditLog[]
  createdCampaigns   WhatsAppCampaign[] @relation("CampaignCreator")
  cancelledCampaigns WhatsAppCampaign[] @relation("CampaignCanceller")

  @@map("auth_user")
}

model Session {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expiresAt            DateTime
  token                String   @unique
  ipAddress            String?
  userAgent            String?
  impersonatedBy       String?
  userId               String   @db.Uuid
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  activeOrganizationId String?  @db.Uuid
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_session")
}

model Account {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("auth_account")
}

model Verification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("auth_verification")
}

// ============================================
// Auth Domain
// ============================================

model DealTracking {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealId      String  @unique @db.Uuid
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  gclid       String?
  fbclid      String?
  ctwaclid    String?
  ttclid      String?

  // Meta Ads Data
  metaAdId         String?
  metaAdSetId      String?
  metaCampaignId   String?
  metaAccountId    String?
  metaAdName       String?
  metaAdSetName    String?
  metaCampaignName String?
  metaPlacement    String?
  metaSourceType   String?

  // Enrichment Control
  metaEnrichmentStatus String    @default("PENDING")
  metaEnrichmentError  String?
  lastEnrichmentAt     DateTime?
  metaAdIdAtEnrichment String?

  sourceType  String   @default("organic")
  referrerUrl String?
  landingPage String?
  userAgent   String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([utmSource])
  @@index([sourceType])
  @@index([ctwaclid])
  @@index([metaAdId])
  @@map("crm_deal_tracking")
}

// ============================================
// Organization Domain
// ============================================

model Organization {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  slug                 String               @unique
  asaasCustomerId      String?              @unique
  logo                 String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  conversations        Conversation[]
  invitations          Invitation[]
  leads                Lead[]
  members              Member[]
  projects             Project[]
  company              OrganizationCompany?
  profile              OrganizationProfile?
  itemCategories       ItemCategory[]
  items                Item[]
  saleItems            SaleItem[]
  sales                Sale[]
  dealStages           DealStage[]
  deals                Deal[]
  dealStageTemplates   DealStageTemplate[]
  whatsappAuditLogs    WhatsAppAuditLog[]   @relation("WhatsAppAuditLogs")
  whatsappConfig       WhatsAppConfig[]
  whatsappConnections  WhatsAppConnection[] @relation("WhatsAppConnections")
  whatsappHealthChecks WhatsAppHealth[]     @relation("WhatsAppHealthChecks")
  whatsappOnboardings  WhatsAppOnboarding[] @relation("WhatsAppOnboardings")
  webhookLogs          WhatsAppWebhookLog[] @relation("WhatsAppWebhookLogs")

  // Meta Ads Relations
  metaConnections      MetaConnection[]
  metaAdAccounts       MetaAdAccount[]
  metaPixels           MetaPixel[]
  metaConversionEvents MetaConversionEvent[]

  // Audit
  orgAuditLogs      OrgAuditLog[]
  billingAuditLogs  BillingAuditLog[]
  organizationRoles OrganizationRole[]

  // Billing
  billingSubscription BillingSubscription?
  billingInvoices     BillingInvoice[]
  whatsAppCampaigns   WhatsAppCampaign[]
  leadTags            LeadTag[]
  contactLists        WhatsAppContactList[]
  audienceSegments    WhatsAppAudienceSegment[]
  whatsAppOptOuts     WhatsAppOptOut[]

  // Analytics
  analyticsSettings OrganizationAnalyticsSettings?
  metaSyncRuns      MetaInsightSyncRun[]
  metaInsights      MetaAdInsightDaily[]
  currencyRates     CurrencyExchangeRateDaily[]
  dashboardMetrics  DashboardDailyMetric[]
  dashboardOrigins  DashboardOriginDailyMetric[]
  dashboardEntities DashboardMetaEntityDailyMetric[]
  dashboardRefreshes DashboardMetricRefreshRun[]

  @@map("org_organizations")
}

model Project {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @db.Uuid
  name           String
  slug           String
  isArchived     Boolean   @default(false)
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization         Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads                Lead[]
  deals                Deal[]
  sales                Sale[]
  items                Item[]
  itemCategories       ItemCategory[]
  whatsappConfigs      WhatsAppConfig[]
  metaAdAccounts       MetaAdAccount[]
  metaConnections      MetaConnection[]
  metaPixels           MetaPixel[]
  whatsAppConnections  WhatsAppConnection[]
  whatsappOnboardings  WhatsAppOnboarding[]
  metaConversionEvents MetaConversionEvent[]
  whatsAppCampaigns    WhatsAppCampaign[]
  audienceSegments     WhatsAppAudienceSegment[]
  dealStageTemplates   DealStageTemplate[]

  // Analytics
  metaSyncRuns      MetaInsightSyncRun[]
  metaInsights      MetaAdInsightDaily[]
  dashboardMetrics  DashboardDailyMetric[]
  dashboardOrigins  DashboardOriginDailyMetric[]
  dashboardEntities DashboardMetaEntityDailyMetric[]
  dashboardRefreshes DashboardMetricRefreshRun[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("crm_projects")
}

model OrganizationProfile {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId          String    @unique @db.Uuid
  cpf                     String?   @unique
  onboardingStatus        String    @default("pending")
  onboardingCompletedAt   DateTime?
  avgDeal                 String?
  attendantsCount         String?
  mainChannel             String?
  leadsPerDay             String?
  monthlyRevenue          String?
  monthlyAdSpend          String?
  estimatedConversionRate Float?
  estimatedCPL            Float?
  estimatedCAC            Float?
  estimatedROAS           Float?
  estimatedLeadValue      Float?
  leadsPerAttendant       Float?
  revenuePerAttendant     Float?
  dealExpirationDays      Int?      @default(30)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_profiles")
}

model Member {
  id                  String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String                     @db.Uuid
  userId              String                     @db.Uuid
  role                String
  createdAt           DateTime
  organization        Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissionOverrides MemberPermissionOverride[]
  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId, role])
  @@map("org_members")
}

model OrganizationRole {
  id             String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                       @db.Uuid
  key            String
  name           String
  description    String?
  isSystem       Boolean                      @default(false)
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  organization   Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions    OrganizationRolePermission[]

  @@unique([organizationId, key])
  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([isSystem])
  @@map("org_roles")
}

model OrganizationRolePermission {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationRoleId String           @db.Uuid
  permissionKey      String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organizationRole   OrganizationRole @relation(fields: [organizationRoleId], references: [id], onDelete: Cascade)

  @@unique([organizationRoleId, permissionKey])
  @@index([organizationRoleId])
  @@index([permissionKey])
  @@map("org_role_permissions")
}

model MemberPermissionOverride {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId      String   @db.Uuid
  permissionKey String
  effect        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  member        Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, permissionKey])
  @@index([memberId])
  @@index([permissionKey])
  @@index([effect])
  @@map("org_member_permission_overrides")
}

model Invitation {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String       @db.Uuid
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_invitations")
}

// ============================================
// CRM Domain
// ============================================

model Lead {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @db.Uuid
  projectId      String?   @db.Uuid
  name           String?
  mail           String?
  phone          String?
  waId           String?   @map("remote_jid")
  pushName       String?
  profilePicUrl  String?
  lastMessageAt  DateTime? @map("last_message_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  sourceId       String    @db.Uuid
  lastSyncedAt   DateTime?
  isActive       Boolean   @default(true)
  deletedAt      DateTime?

  // KPIs
  firstMessageAt DateTime?
  totalDeals     Int       @default(0)
  lifetimeValue  Decimal   @default(0) @db.Decimal(12, 2)

  conversations              Conversation[]
  organization               Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project                    Project?                    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  source                     LeadSource                  @relation(fields: [sourceId], references: [id])
  messages                   Message[]
  deals                      Deal[]
  whatsAppCampaignRecipients WhatsAppCampaignRecipient[]
  tagAssignments             LeadTagAssignment[]

  @@unique([organizationId, waId])
  @@index([organizationId])
  @@index([organizationId, phone])
  @@index([projectId])
  @@index([organizationId, projectId])
  @@index([sourceId])
  @@index([isActive])
  @@map("crm_leads")
}

model Conversation {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String  @db.Uuid
  projectId          String? @db.Uuid
  leadId             String  @db.Uuid
  instanceId         String  @db.Uuid
  metaConversationId String?
  messagesCount      Int     @default(0)

  // KPIs
  unreadCount           Int       @default(0)
  inboundMessagesCount  Int       @default(0)
  outboundMessagesCount Int       @default(0)
  lastInboundAt         DateTime?
  lastOutboundAt        DateTime?
  avgResponseTimeSec    Int?
  firstResponseTimeSec  Int?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  instance     WhatsAppConfig @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deals        Deal[]
  messages     Message[]

  @@unique([leadId, instanceId])
  @@index([organizationId])
  @@index([projectId])
  @@map("crm_conversations")
}

model Deal {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String    @db.Uuid
  projectId       String?   @db.Uuid
  conversationId  String    @db.Uuid
  stageId         String    @db.Uuid
  stageEnteredAt  DateTime?
  windowExpiresAt DateTime?
  windowOpen      Boolean   @default(true)
  assigneeId      String?   @db.Uuid
  dealValue       Decimal?  @db.Decimal(12, 2)
  statusId        String    @db.Uuid
  closedAt        DateTime?
  closedReason    String?
  createdBy       String    @default("SYSTEM")
  messagesCount   Int       @default(0)
  position        Float     @default(0)

  // KPIs
  inboundMessagesCount  Int       @default(0)
  outboundMessagesCount Int       @default(0)
  lastInboundAt         DateTime?
  lastOutboundAt        DateTime?
  firstResponseTimeSec  Int?
  resolutionTimeSec     Int?

  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  leadId                 String                   @db.Uuid
  source                 String                   @default("incoming_message")
  originatedFrom         String?
  sales                  Sale[]
  tracking               DealTracking?
  assignee               User?                    @relation("DealAssignee", fields: [assigneeId], references: [id])
  conversation           Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project                Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  stage                  DealStage                @relation(fields: [stageId], references: [id])
  status                 DealStatus               @relation(fields: [statusId], references: [id])
  lead                   Lead                     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages               Message[]
  metaAttributionHistory MetaAttributionHistory[]

  @@index([organizationId])
  @@index([projectId])
  @@index([organizationId, projectId])
  @@index([conversationId])
  @@index([statusId])
  @@index([leadId])
  @@index([stageId])
  @@map("crm_deals")
}

model DealStage {
  id                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId         String              @db.Uuid
  projectId              String?             @db.Uuid
  name                   String
  color                  String
  order                  Int
  statusGroup            String              @default("ACTIVE") // ACTIVE | WON | LOST | PAUSED
  probability            Int                 @default(0) // 0-100% forecasting
  isDefault              Boolean             @default(false)
  isClosed               Boolean             @default(false)
  suggestedMetaEventName String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deals          Deal[]
  metaRules      DealStageMetaRule[]

  @@unique([organizationId, projectId, name])
  @@index([organizationId, projectId, order])
  @@map("crm_deal_stages")
}

model Sale {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String       @db.Uuid
  projectId       String?      @db.Uuid
  totalAmount     Decimal?     @db.Decimal(12, 2)
  profit          Decimal?     @db.Decimal(12, 2)
  discount        Decimal?     @db.Decimal(12, 2)
  status          String?      @default("pending")
  notes           String?
  createdBy       String?
  updatedBy       String?
  statusChangedAt DateTime?
  dealId          String?      @db.Uuid
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @default(now()) @updatedAt
  items           SaleItem[]
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  statusRef       SaleStatus?  @relation(fields: [status], references: [name])
  deal            Deal?        @relation(fields: [dealId], references: [id])

  @@index([organizationId])
  @@index([projectId])
  @@index([organizationId, projectId])
  @@index([createdAt])
  @@index([dealId])
  @@map("crm_sales")
}

model SaleItem {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  saleId         String       @db.Uuid
  itemId         String?      @db.Uuid
  name           String
  quantity       Int          @default(1)
  unitPrice      Decimal      @db.Decimal(12, 2)
  total          Decimal      @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item           Item?        @relation(fields: [itemId], references: [id])
  sale           Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([saleId])
  @@index([itemId])
  @@map("crm_sale_items")
}

model Item {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @db.Uuid
  projectId      String?       @db.Uuid
  categoryId     String?       @db.Uuid
  name           String
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
  category       ItemCategory? @relation(fields: [categoryId], references: [id])
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  saleItems      SaleItem[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([projectId])
  @@index([organizationId, projectId])
  @@index([active])
  @@map("crm_items")
}

model ItemCategory {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  projectId      String?      @db.Uuid
  name           String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items          Item[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([projectId])
  @@index([organizationId, projectId])
  @@index([active])
  @@map("crm_item_categories")
}

model OrganizationCompany {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        String       @unique @db.Uuid
  cnpj                  String       @unique
  razaoSocial           String
  nomeFantasia          String?
  cnaeCode              String
  cnaeDescription       String
  municipio             String
  uf                    String       @db.Char(2)
  tipo                  String?
  porte                 String?
  naturezaJuridica      String?
  capitalSocial         Decimal?
  situacao              String?
  dataAbertura          DateTime?
  dataSituacao          DateTime?
  simplesOptante        Boolean      @default(false)
  simeiOptante          Boolean      @default(false)
  logradouro            String?
  numero                String?
  complemento           String?
  bairro                String?
  cep                   String?
  email                 String?
  telefone              String?
  qsa                   Json?
  atividadesSecundarias Json?
  authorizedByUserId    String       @db.Uuid
  authorizedAt          DateTime     @default(now())
  fetchedAt             DateTime     @default(now())
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([cnaeCode])
  @@index([porte])
  @@index([uf])
  @@index([situacao])
  @@map("org_companies")
}

// ============================================
// WhatsApp Domain
// ============================================

model WhatsAppConfig {
  id                             String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId                 String                          @db.Uuid
  projectId                      String                          @db.Uuid
  connectionId                   String?                         @db.Uuid
  wabaId                         String?
  phoneId                        String?                         @unique
  accessToken                    String?
  displayPhone                   String?
  verifiedName                   String?
  status                         String                          @default("pending")
  authorizationCode              String?
  accessTokenEncrypted           Boolean                         @default(false)
  tokenExpiresAt                 DateTime?
  tokenLastCheckedAt             DateTime?
  tokenStatus                    String?
  connectedAt                    DateTime?
  disconnectedAt                 DateTime?
  disconnectedBy                 String?                         @db.Uuid
  lastWebhookAt                  DateTime?
  processed                      Boolean                         @default(false)
  processingError                String?
  retryCount                     Int                             @default(0)
  historySyncStatus              String?
  historySyncStartedAt           DateTime?
  historySyncCompletedAt         DateTime?
  historySyncProgress            Int                             @default(0)
  historySyncPhase               Int?
