// ============================================
// Multi-Agent Platform (Copilot 2.0)
// ============================================

model AiTriggerEventType {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String      @unique
  description String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  triggers    AiTrigger[]

  @@map("ai_trigger_event_types")
}

model AiSchemaFieldType {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String          @unique
  description String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  fields      AiSchemaField[]

  @@map("ai_schema_field_types")
}

model AiInsightActionStatus {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String      @unique
  description String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  insights    AiInsight[]

  @@map("ai_insight_action_statuses")
}

model AiAgent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  icon           String?
  leanPrompt     String   @db.Text
  model          String   @default("llama-3.3-70b-versatile")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  triggers     AiTrigger[]
  schemaFields AiSchemaField[]
  insights     AiInsight[]
  skillBindings AiAgentSkill[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("ai_agents")
}

model AiSkill {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  slug           String
  name           String
  description    String?
  content        String   @db.Text
  kind           String   @default("SHARED") // SHARED | AGENT
  source         String   @default("CUSTOM") // SYSTEM | CUSTOM
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bindings     AiAgentSkill[]

  @@unique([organizationId, slug])
  @@index([organizationId, source, kind])
  @@map("ai_skills")
}

model AiAgentSkill {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId   String   @db.Uuid
  skillId   String   @db.Uuid
  sortOrder Int      @default(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill AiSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([agentId, skillId])
  @@index([agentId, sortOrder])
  @@map("ai_agent_skills")
}

model AiTrigger {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId    String   @db.Uuid
  eventType  String   @default("TICKET_CLOSED") // Points to AiTriggerEventType.name
  conditions Json     @default("{}") // Used to evaluate if trigger should fire
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  agent   AiAgent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  typeRef AiTriggerEventType @relation(fields: [eventType], references: [name])

  @@index([agentId])
  @@map("ai_triggers")
}

model AiSchemaField {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId     String   @db.Uuid
  fieldName   String
  fieldType   String   @default("STRING") // Points to AiSchemaFieldType.name
  description String   @db.Text
  isRequired  Boolean  @default(true)
  options     Json? // Array of possible values if fieldType is ENUM
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent   AiAgent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  typeRef AiSchemaFieldType @relation(fields: [fieldType], references: [name])

  @@unique([agentId, fieldName])
  @@index([agentId])
  @@map("ai_schema_fields")
}

model AiInsight {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String  @db.Uuid
  ticketId       String? @db.Uuid // Optional: null for audit events, required for ticket events
  agentId        String  @db.Uuid
  eventType      String? // Event trigger type (e.g., "META_ADS_AUDIT_REQUESTED", "CONVERSATION_IDLE_3M")

  payload Json // The raw JSON result from Mastra (Zod output)
  status  String @default("SUGGESTION") // Points to AiInsightActionStatus.name

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket       Ticket?               @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  agent        AiAgent               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  statusRef    AiInsightActionStatus @relation(fields: [status], references: [name])
  costs        AiInsightCost[]

  @@index([organizationId])
  @@index([ticketId])
  @@index([agentId])
  @@index([organizationId, eventType, createdAt])
  @@map("ai_insights")
}

model OrgAuditLog {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?      @db.Uuid    // nullable: suporte a eventos globais (ex: registro)
  userId         String?      @db.Uuid    // nullable: suporte a ações de sistema
  action         String
  resourceType   String
  resourceId     String?
  before         Json?
  after          Json?
  ip             String?
  userAgent      String?
  requestId      String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@index([requestId])
  @@map("org_audit_logs")
}

// ============================================
// Billing Domain
// ============================================

model BillingSubscription {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String @db.Uuid
  planId         String?

  // Provider
  provider               String
  providerCustomerId     String  @unique
  providerSubscriptionId String? @unique

  // Billing cycle
  billingCycleStartDate DateTime
  billingCycleEndDate   DateTime
  nextResetDate         DateTime
  trialEndsAt           DateTime?

  // Status
  status              String                    @default("active") // 'active' | 'paused' | 'canceled' | 'past_due'
  statusRef           BillingSubscriptionStatus @relation(fields: [status], references: [name])
  canceledAtPeriodEnd Boolean @default(false)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  canceledAt DateTime?

  items          BillingSubscriptionItem[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan           BillingPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@unique([organizationId])
  @@index([status])
  @@index([nextResetDate])
  @@map("billing_subscriptions")
}

model BillingSubscriptionItem {
  id                       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId           String @db.Uuid
  planId                   String
  stripeSubscriptionItemId String? @unique
  quantity                 Int    @default(0)
  unitPrice                Decimal @db.Decimal(10, 2)
  currency                 String  @default("BRL")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  subscription BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  plan         BillingPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, planId])
  @@index([subscriptionId])
  @@index([planId])
  @@map("billing_subscription_items")
}

model BillingWebhookLog {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  provider    String
  eventType   String  // 'subscription.created' | 'charge.paid' | etc
  payload     Json
  eventId     String? @unique  // ID do evento no provider (deduplicação)

  isProcessed     Boolean   @default(false)
  processingError String?
  processedAt     DateTime?

  retryCount  Int       @default(0)
  lastRetryAt DateTime?

  createdAt DateTime @default(now())

  @@index([isProcessed])
  @@index([provider])
  @@index([createdAt])
  @@map("billing_webhook_logs")
}

model BillingPlan {
  id String @id @default(cuid())

  // Identificação
  name        String @unique
  slug        String @unique
  description String?

  kind        String  // 'base' | 'addon'
  addonType   String? // 'project' | 'whatsapp_number' | 'meta_ad_account'

  // Preço
  monthlyPrice Decimal @db.Decimal(10, 2)
  currency     String  @default("BRL")

  // Entitlements
  includedProjects              Int    @default(0)
  includedWhatsAppPerProject    Int    @default(0)
  includedMetaAdAccountsPerProject Int @default(0)
  includedConversionsPerProject Int    @default(0)
  includedAiCreditsPerProject   Int    @default(0)
  supportLevel                  String

  // Stripe Sync
  stripeProductId       String?  @unique
  stripePriceId         String?  @unique
  syncStatus            String   @default("pending")
  syncError             String?
  syncedAt              DateTime?

  // Display
  isActive              Boolean  @default(true)
  displayOrder          Int      @default(0)
  isHighlighted         Boolean  @default(false)
  contactSalesOnly      Boolean  @default(false)

  // Metadata
  metadata              Json?

  // Audit
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  createdBy             String?
  deletedAt             DateTime?

  // Relations
  history               BillingPlanHistory[]
  subscriptions         BillingSubscription[]
  subscriptionItems     BillingSubscriptionItem[]

  @@index([slug])
  @@index([kind])
  @@index([addonType])
  @@index([isActive])
  @@index([stripeProductId])
  @@map("billing_plans")
}

model BillingPlanHistory {
  id String @id @default(cuid())

  planId String
  plan   BillingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  // Ação
  action String   // "created" | "updated" | "synced" | "deleted"

  // Valores
  oldValues Json?
  newValues Json?

  // Stripe Sync
  syncAction  String?
  syncResult  Json?
  syncError   String?

  // Audit
  changedBy   String?
  changedAt   DateTime @default(now())

  @@index([planId, changedAt])
  @@map("billing_plan_history")
}

model AiInsightCost {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  aiInsightId    String   @db.Uuid

  // Context
  feature        String   // "meta-ads-audit", "ticket-analysis", etc
  operation      String   // "account-analysis", "conversation-idle", etc
  agentName      String   // "Meta Ads Analyst", "Sale Detector", etc
  eventType      String   // "META_ADS_AUDIT_REQUESTED", "CONVERSATION_IDLE_3M", etc

  // Tokens & Cost
  inputTokens    Int
  outputTokens   Int
  totalTokens    Int      // computed: input + output
  modelUsed      String   // "openai/gpt-4o-mini", "groq/mixtral-8x7b"
  inputCost      Decimal  @db.Decimal(10, 6) // tokens * rate / 1M
  outputCost     Decimal  @db.Decimal(10, 6) // tokens * rate / 1M
  totalCost      Decimal  @db.Decimal(10, 6) // inputCost + outputCost

  // Performance
  latencyMs      Int?     // tempo total da execução
  status         String   // "success", "error", "timeout"
  errorMessage   String?

  // Audit
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  insight        AiInsight    @relation(fields: [aiInsightId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([feature, createdAt])
  @@index([status, createdAt])
  @@index([organizationId, eventType, createdAt])
  @@map("ai_insight_costs")
}
