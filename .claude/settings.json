{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; if [[ \"$f\" =~ \\.(ts|tsx|js|jsx)$ ]]; then npm run lint -- \"$f\" 2>/dev/null || true; fi; }",
            "statusMessage": "Running eslint...",
            "async": true
          }
        ]
      }
    ]
  }
}
